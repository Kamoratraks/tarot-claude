import { useState } from "react";

const TAROT_CARDS = [
  { name: "The Fool", th: "คนโง่", emoji: "🃏" },
  { name: "The Magician", th: "จอมเวทย์", emoji: "🎩" },
  { name: "The High Priestess", th: "นักบวชหญิง", emoji: "🌙" },
  { name: "The Empress", th: "จักรพรรดินี", emoji: "👑" },
  { name: "The Emperor", th: "จักรพรรดิ", emoji: "⚔️" },
  { name: "The Hierophant", th: "นักบวช", emoji: "🕍" },
  { name: "The Lovers", th: "คู่รัก", emoji: "💕" },
  { name: "The Chariot", th: "รถศึก", emoji: "🏆" },
  { name: "Strength", th: "ความแข็งแกร่ง", emoji: "🦁" },
  { name: "The Hermit", th: "ฤาษี", emoji: "🕯️" },
  { name: "Wheel of Fortune", th: "วงล้อโชคชะตา", emoji: "🎡" },
  { name: "Justice", th: "ความยุติธรรม", emoji: "⚖️" },
  { name: "The Hanged Man", th: "ชายถูกแขวน", emoji: "🙃" },
  { name: "Death", th: "ความตาย", emoji: "💀" },
  { name: "Temperance", th: "ความพอดี", emoji: "⚗️" },
  { name: "The Devil", th: "ปีศาจ", emoji: "😈" },
  { name: "The Tower", th: "หอคอย", emoji: "🗼" },
  { name: "The Star", th: "ดาว", emoji: "⭐" },
  { name: "The Moon", th: "พระจันทร์", emoji: "🌕" },
  { name: "The Sun", th: "พระอาทิตย์", emoji: "☀️" },
  { name: "Judgement", th: "การพิพากษา", emoji: "📯" },
  { name: "The World", th: "โลก", emoji: "🌍" },
  { name: "Ace of Wands", th: "เอซไม้เท้า", emoji: "🪄" },
  { name: "Two of Cups", th: "สองถ้วย", emoji: "🥂" },
  { name: "Three of Swords", th: "สามดาบ", emoji: "💔" },
  { name: "Four of Pentacles", th: "สี่เหรียญ", emoji: "💰" },
  { name: "Five of Wands", th: "ห้าไม้เท้า", emoji: "⚡" },
  { name: "Six of Cups", th: "หกถ้วย", emoji: "🌸" },
  { name: "Seven of Swords", th: "เจ็ดดาบ", emoji: "🗡️" },
  { name: "Eight of Cups", th: "แปดถ้วย", emoji: "🚶" },
  { name: "Nine of Pentacles", th: "เก้าเหรียญ", emoji: "🍇" },
  { name: "Ten of Wands", th: "สิบไม้เท้า", emoji: "😮‍💨" },
  { name: "Page of Cups", th: "เด็กรับใช้ถ้วย", emoji: "🐟" },
  { name: "Knight of Swords", th: "อัศวินดาบ", emoji: "🌪️" },
  { name: "Queen of Pentacles", th: "ราชินีเหรียญ", emoji: "🌿" },
  { name: "King of Cups", th: "กษัตริย์ถ้วย", emoji: "🌊" },
];

export default function TarotApp() {
  const [question, setQuestion] = useState("");
  const [drawnCard, setDrawnCard] = useState(null);
  const [reading, setReading] = useState("");
  const [isLoading, setIsLoading] = useState(false);
  const [isReversed, setIsReversed] = useState(false);
  const [flipped, setFlipped] = useState(false);
  const [phase, setPhase] = useState("input");

  const handleSubmit = async () => {
    if (!question.trim()) return;
    setIsLoading(true);
    setPhase("drawing");
    setFlipped(false);
    setReading("");

    const card = TAROT_CARDS[Math.floor(Math.random() * TAROT_CARDS.length)];
    const reversed = Math.random() > 0.65;
    setDrawnCard(card);
    setIsReversed(reversed);

    await new Promise(r => setTimeout(r, 900));
    setFlipped(true);
    await new Promise(r => setTimeout(r, 700));

    const prompt = `คุณชื่อ "มีนา" เพื่อนที่อ่านไพ่ทาโรต์เป็น คุยกับเพื่อนแบบสนิท ใช้ "เธอ" แทนคนถาม ใช้ภาษาพูดธรรมชาติ

ไพ่ที่จั่วได้: ${card.name} (${card.th}) ${reversed ? "[กลับหัว]" : ""}
คำถาม: "${question}"

กฎการตอบ:
1. ตอบตรงกับคำถามนี้เลย ไม่ต้องอธิบายความหมายไพ่ทั่วไป
2. พูดเหมือนพี่น้องคุยกัน ไม่ใช่ AI อธิบาย
3. ถ้าถามว่าใครได้/ใครชนะ/จะเกิดอะไร — บอกเลย ไม่ต้อง "อาจจะ"
4. ไม่ต้องขึ้นต้นด้วยชื่อไพ่ ไม่ต้องสรุปท้าย ไม่ต้องบอกว่า "ไพ่บอกว่า"
5. กระชับ 3-5 ประโยคพอ เน้นใจความ
6. ถ้าคำถามเป็นเรื่องละเอียดอ่อน (ความตาย สุขภาพ เรื่องคู่ เรื่อง 18+) ตอบตรงๆ ไม่หลบ ไม่เบี่ยง
7. ห้ามหยาบคาย ไม่อคติ มีเหตุผล ตรงไปตรงมา ไม่ต้องสุภาพเกินจริง`;

    try {
      const response = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{ role: "user", content: prompt }],
        }),
      });
      const data = await response.json();
      const text = data.content?.map(b => b.text || "").join("") || "อ่านไม่ออก ลองใหม่นะ";
      setReading(text);
    } catch {
      setReading("เชื่อมต่อไม่ได้ ลองอีกทีนะ");
    }

    setIsLoading(false);
    setPhase("result");
  };

  const reset = () => {
    setQuestion("");
    setDrawnCard(null);
    setReading("");
    setFlipped(false);
    setPhase("input");
  };

  return (
    <div style={{
      minHeight: "100vh",
      background: "linear-gradient(160deg, #0a0015 0%, #1a0030 60%, #0d001a 100%)",
      fontFamily: "'Georgia', serif",
      color: "#e8d5ff",
      display: "flex",
      flexDirection: "column",
      alignItems: "center",
      padding: "40px 20px",
    }}>
      <div style={{
        position: "fixed", inset: 0, pointerEvents: "none",
        background: "radial-gradient(ellipse at 30% 20%, rgba(100,30,180,0.12) 0%, transparent 55%), radial-gradient(ellipse at 70% 80%, rgba(50,0,100,0.18) 0%, transparent 55%)",
      }} />

      {/* Header */}
      <div style={{ textAlign: "center", marginBottom: "36px" }}>
        <div style={{ fontSize: "13px", letterSpacing: "5px", color: "#8050c0", marginBottom: "6px" }}>✦ ✦ ✦</div>
        <h1 style={{
          fontSize: "clamp(26px, 5vw, 44px)", fontWeight: "normal",
          color: "#f0e0ff", margin: 0, letterSpacing: "3px",
          textShadow: "0 0 25px rgba(160,80,255,0.45)",
        }}>มีนา ทาโรต์</h1>
        <p style={{ color: "#7a50a0", fontSize: "13px", margin: "6px 0 0", letterSpacing: "1px" }}>
          ถามได้ทุกเรื่อง · ตอบตรง · ไม่อ้อมค้อม
        </p>
      </div>

      {/* Input */}
      {phase === "input" && (
        <div style={{ width: "100%", maxWidth: "520px" }}>
          <div style={{
            background: "rgba(70,15,130,0.22)",
            border: "1px solid rgba(150,70,240,0.28)",
            borderRadius: "16px", padding: "28px",
            backdropFilter: "blur(8px)",
          }}>
            <p style={{ margin: "0 0 18px", fontSize: "15px", color: "#b090e0", lineHeight: 1.65 }}>
              ถามเรื่องอะไรก็ได้ — ความรัก งาน เงิน สุขภาพ การเมือง ฯลฯ
            </p>
            <textarea
              value={question}
              onChange={e => setQuestion(e.target.value)}
              placeholder="พิมพ์คำถามที่นี่..."
              rows={4}
              style={{
                width: "100%", boxSizing: "border-box",
                background: "rgba(15,0,35,0.65)",
                border: "1px solid rgba(130,55,210,0.38)",
                borderRadius: "10px", padding: "14px",
                color: "#e8d5ff", fontSize: "16px",
                fontFamily: "inherit", resize: "vertical", outline: "none", lineHeight: 1.65,
              }}
            />
            <button
              onClick={handleSubmit}
              disabled={!question.trim()}
              style={{
                marginTop: "14px", width: "100%", padding: "15px",
                background: question.trim()
                  ? "linear-gradient(135deg, #6018b0, #9030d0)"
                  : "rgba(50,15,90,0.4)",
                border: "none", borderRadius: "10px",
                color: question.trim() ? "#fff" : "#50308a",
                fontSize: "15px", letterSpacing: "2px",
                cursor: question.trim() ? "pointer" : "not-allowed",
                fontFamily: "inherit", transition: "all 0.3s",
              }}
            >
              🔮 จั่วไพ่
            </button>
          </div>
        </div>
      )}

      {/* Card + Reading */}
      {(phase === "drawing" || phase === "result") && drawnCard && (
        <div style={{ width: "100%", maxWidth: "520px" }}>
          {/* Question */}
          <div style={{
            background: "rgba(50,8,90,0.28)",
            border: "1px solid rgba(110,45,190,0.28)",
            borderRadius: "10px", padding: "11px 18px",
            marginBottom: "22px", fontSize: "14px", color: "#9060c0",
          }}>
            <span style={{ color: "#5a2880" }}>คำถาม: </span>{question}
          </div>

          {/* Card flip */}
          <div style={{ display: "flex", justifyContent: "center", marginBottom: "26px" }}>
            <div style={{ width: "155px", height: "255px", perspective: "1000px" }}>
              <div style={{
                width: "100%", height: "100%", position: "relative",
                transformStyle: "preserve-3d",
                transition: "transform 0.85s cubic-bezier(0.4,0,0.2,1)",
                transform: flipped
                  ? isReversed ? "rotateY(180deg) rotate(180deg)" : "rotateY(180deg)"
                  : "rotateY(0deg)",
              }}>
                {/* Back */}
                <div style={{
                  position: "absolute", inset: 0, backfaceVisibility: "hidden",
                  background: "linear-gradient(135deg, #280048, #480088)",
                  border: "2px solid rgba(150,70,240,0.38)",
                  borderRadius: "14px", display: "flex",
                  alignItems: "center", justifyContent: "center", fontSize: "46px",
                }}>🔮</div>
                {/* Front */}
                <div style={{
                  position: "absolute", inset: 0, backfaceVisibility: "hidden",
                  transform: "rotateY(180deg)",
                  background: "linear-gradient(155deg, #180030, #380068)",
                  border: "2px solid rgba(190,110,255,0.55)",
                  borderRadius: "14px",
                  display: "flex", flexDirection: "column",
                  alignItems: "center", justifyContent: "center", gap: "10px",
                  boxShadow: flipped ? "0 0 35px rgba(150,70,255,0.35)" : "none",
                }}>
                  <div style={{ fontSize: "52px" }}>{drawnCard.emoji}</div>
                  <div style={{ fontSize: "12px", color: "#b080f0", textAlign: "center", padding: "0 10px", letterSpacing: "0.5px" }}>
                    {drawnCard.name}
                  </div>
                  <div style={{ fontSize: "14px", color: "#ddbcff", fontWeight: "bold", textAlign: "center" }}>
                    {drawnCard.th}
                  </div>
                  {isReversed && (
                    <div style={{ fontSize: "10px", color: "#ff7575", letterSpacing: "1px" }}>กลับหัว</div>
                  )}
                </div>
              </div>
            </div>
          </div>

          {/* Reading */}
          {phase === "result" && (
            <div style={{
              background: "rgba(35,8,70,0.48)",
              border: "1px solid rgba(150,70,240,0.22)",
              borderRadius: "14px", padding: "24px",
              marginBottom: "20px",
              backdropFilter: "blur(6px)",
              animation: "fadeUp 0.5s ease",
            }}>
              <p style={{ margin: 0, lineHeight: 1.85, fontSize: "16px", color: "#e8d5ff", whiteSpace: "pre-wrap" }}>
                {reading}
              </p>
            </div>
          )}

          {isLoading && (
            <div style={{ textAlign: "center", color: "#8050b8", fontSize: "14px", padding: "10px 0" }}>
              กำลังอ่านไพ่...
            </div>
          )}

          {phase === "result" && (
            <button onClick={reset} style={{
              width: "100%", padding: "13px",
              background: "transparent",
              border: "1px solid rgba(130,55,210,0.42)",
              borderRadius: "10px", color: "#9060c0",
              fontSize: "14px", cursor: "pointer",
              fontFamily: "inherit", letterSpacing: "1px",
            }}>
              ถามอีกครั้ง
            </button>
          )}
        </div>
      )}

      <style>{`
        @keyframes fadeUp {
          from { opacity: 0; transform: translateY(8px); }
          to { opacity: 1; transform: translateY(0); }
        }
        textarea:focus {
          border-color: rgba(170,90,255,0.55) !important;
        }
      `}</style>
    </div>
  );
}
